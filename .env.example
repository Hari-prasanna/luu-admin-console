# Auth & database — copy to .env and fill in real values
# Generate AUTH_SECRET: openssl rand -hex 32

AUTH_SECRET=replace-with-32-char-random-secret

AUTH_BOOTSTRAP_ADMIN_USER=admin
AUTH_BOOTSTRAP_ADMIN_PASSWORD=replace-with-strong-password

AUTH_BOOTSTRAP_USER=operator
AUTH_BOOTSTRAP_USER_PASSWORD=replace-with-strong-password

POSTGRES_PASSWORD=replace-with-strong-password
