# Template for the SECURE credentials file.
# Copy this to a protected location OUTSIDE the repo, e.g.:
#     mkdir -p ~/.config/oracle-tv-dashboard
#     cp oracle.env.example ~/.config/oracle-tv-dashboard/oracle.env
#     chmod 600 ~/.config/oracle-tv-dashboard/oracle.env
# Then fill in the real values. The butler reads this file automatically.

ORA_USER=your_readonly_user
ORA_HOST=your.oracle.host
ORA_PORT=1521
ORA_SERVICE=your_service_name
ORA_PASSWORD=your_password_here
# One global webhook URL reused by every dashboard. Leave blank to disable alerts.
# Alerts fire only when a dashboard starts failing or recovers (never every run).
CHAT_WEBHOOK_URL=