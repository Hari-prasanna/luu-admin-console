      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has success status', function() {",
                  "  var jsonData = pm.response.json();",
                  "  pm.expect(jsonData.status).to.equal('success');",
                  "});",
                  "",
                  "pm.test('Response contains access_token', function() {",
                  "  var jsonData = pm.response.json();",
                  "  pm.expect(jsonData.data.access_token).to.be.a('string');",
                  "  pm.expect(jsonData.data.access_token.length).to.be.above(0);",
                  "});",
                  "",
                  "pm.test('Token type is bearer', function() {",
                  "  var jsonData = pm.response.json();",
                  "  pm.expect(jsonData.data.token_type).to.equal('bearer');",
                  "});",
                  "",
                  "pm.test('Store token in environment', function() {",
                  "  var jsonData = pm.response.json();",
                  "  pm.environment.set('jwt_token', jsonData.data.access_token);",
                  "});",
                  "",
                  "pm.test('Response time is less than 1000ms', function() {",
                  "  pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "});"
                ]
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Pre-request script for login",
                  "// Verify required environment variables",
                  "const baseUrl = pm.environment.get('base_url');",
                  "if (!baseUrl) {",
                  "  throw new Error('base_url environment variable is not set');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
